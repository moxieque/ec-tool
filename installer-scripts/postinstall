#!/bin/bash
# Zaikore PKG postinstall script
# インストール後の自動セットアップ

APP_PATH="/Applications/Zaikore.app"

# Gatekeeper quarantine 属性を除去（警告回避）
xattr -rd com.apple.quarantine "$APP_PATH" 2>/dev/null || true

# 実行権限を付与
chmod -R 755 "$APP_PATH" 2>/dev/null || true

# 起動スクリプトを /Applications に配置
cat > "/Applications/Zaikore 起動.command" << 'LAUNCH_EOF'
#!/bin/bash
# Zaikore 起動スクリプト
# ダブルクリックで起動 → サーバー起動 → ブラウザ自動オープン

PROJECT_DIR="/Users/inamikatsutoshi/Documents/Claude/moxieque-ec-tool"
PORT=8080
MAX_WAIT=30

echo ""
echo "========================================="
echo "✨ Zaikore を起動中..."
echo "========================================="
echo ""

# 既に起動中のプロセスを停止
pkill -f "app.py" 2>/dev/null

# サーバー起動
cd "$PROJECT_DIR"
python3 app.py > /tmp/zaikore.log 2>&1 &
SERVER_PID=$!

echo "⏳ サーバー起動待機中..."
sleep 2

# サーバーが起動するのを待つ（最大30秒）
COUNTER=0
while ! curl -s "http://localhost:$PORT" > /dev/null 2>&1; do
    if [ $COUNTER -ge $MAX_WAIT ]; then
        echo ""
        echo "❌ サーバーの起動がタイムアウトしました"
        echo ""
        echo "ログを確認:"
        echo "  tail -20 /tmp/zaikore.log"
        read -p "Enter キーで閉じます..."
        exit 1
    fi
    sleep 1
    COUNTER=$((COUNTER + 1))
done

echo "✅ サーバーが起動しました"
echo ""
echo "📱 ブラウザを起動中..."

# ブラウザを自動起動
open "http://localhost:$PORT" || \
open -a "Google Chrome" "http://localhost:$PORT" || \
open -a "Safari" "http://localhost:$PORT"

sleep 1

echo ""
echo "========================================="
echo "✅ Zaikore が起動しました！"
echo "========================================="
echo ""
echo "📍 ブラウザで http://localhost:$PORT"
echo "   にアクセスしています"
echo ""
echo "このウィンドウは閉じても大丈夫です"
echo ""
LAUNCH_EOF

chmod 755 "/Applications/Zaikore 起動.command"

# アンインストーラーを /Applications に配置
cat > "/Applications/Zaikore アンインストール.command" << 'UNINSTALL_EOF'
#!/bin/bash
# Zaikore アンインストーラー
# ダブルクリックで実行できます

echo ""
echo "========================================="
echo "  Zaikore アンインストーラー"
echo "========================================="
echo ""

# 確認
echo "Zaikore をアンインストールしますか？"
echo "（ユーザーデータは保持されます）"
echo ""
read -p "続行するには y を入力してください: " confirm

if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo ""
    echo "アンインストールを中止しました。"
    echo ""
    read -p "Enter キーで閉じます..."
    exit 0
fi

echo ""
echo "アンインストール中..."

# Zaikore プロセスを停止
pkill -f "Zaikore" 2>/dev/null || true
lsof -ti:8080 | xargs kill 2>/dev/null || true
sleep 1

# アプリケーション本体を削除
if [ -d "/Applications/Zaikore.app" ]; then
    rm -rf "/Applications/Zaikore.app"
    echo "  [OK] Zaikore.app を削除しました"
else
    echo "  [--] Zaikore.app は見つかりませんでした"
fi

# PKG レシート（インストール記録）を削除
if pkgutil --pkgs 2>/dev/null | grep -q "com.moxieque.zaikore"; then
    sudo pkgutil --forget "com.moxieque.zaikore" 2>/dev/null
    echo "  [OK] インストール記録を削除しました"
fi

# このアンインストーラー自身を削除
SELF_PATH="/Applications/Zaikore アンインストール.command"
if [ -f "$SELF_PATH" ]; then
    rm -f "$SELF_PATH"
    echo "  [OK] アンインストーラーを削除しました"
fi

echo ""
echo "========================================="
echo "  アンインストール完了"
echo "========================================="
echo ""
echo "※ ユーザーデータ（商品・仕入れ・販売データ）は"
echo "  削除されていません。"
echo ""
read -p "Enter キーで閉じます..."
UNINSTALL_EOF

chmod 755 "/Applications/Zaikore アンインストール.command"

exit 0
